configuration {
	drun-display-format: "{name}";
	font: "MapleMono NF CN 24";
	modi: "drun,run,emoji";

	sort: true;
	history: false;
	case-sensitivity: false;
	sorting-method: "fzf";
	matching: "fuzzy";
	hide-scrollbar: true;
	terminal: "foot";
	sidebar-mode: true;
	hover-select: true;
}

@theme "~/.config/rofi/colours.rasi"

window {
	background-color: @main-bg;
	border: 0.2em;
	border-color: @border;
	border-radius: 1.5em;
	height: 15em;
	width: 37.5em;
}

mainbox {
	background-color: transparent;
	orientation: horizontal;
	children: [ omori, listbox ];
}

omori {
	background-color: transparent;
	background-image: url("background.png", height);
}

listbox {
	width: 15em;
	padding: 0.5em;
	expand: false;
	orientation: vertical;
	children: [ inputbar, listview, mode-switcher ];
	background-color: transparent;
}

listview {
	background-color: transparent;
	padding: 0em 0em;
	expand: false;
	lines: 6;
}

mode-switcher {
	background-color: transparent;
}

button {
	background-color: transparent;
	text-color: @passive-text;
}

button.selected {
	background-color: transparent;
	text-color: @active-text;
}

inputbar {
	padding: 0.2em;
	background-color: transparent;
}
prompt {
	text-color: @active-text;
	background-color: transparent;
}

case-indicator {
	enabled: false;
}

element {
	background-color: transparent;
	orientation: horizontal;
	children: [ element-text, element-icon ];
	spacing: 0em;
}

element-icon {
	background-color: transparent;
	padding: 0.2em 0.4em 0.2em 0em;
	size: 1.4em;
}

entry,
element-text {
	padding: 0em 0.5em;
	text-color: @passive-text;
	background-color: transparent;
	highlight: #ffaa00;
}

element-text {
	vertical-align: 0.5;
}

element.selected {
	background-color: @active-bg;
	border-radius: 0.8em;
}
element-text.selected {
	text-color: @active-text;
	highlight: underline bold #aaffaa;
}
